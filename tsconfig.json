{
    "compilerOptions": {
      "target": "es2019",
      "module": "commonjs",
      "declaration": true,          // emit .d.ts files
      "outDir": "dist",
      "strict": true,
      "esModuleInterop": true,
      "skipLibCheck": true,
      "jsx": "react-jsx",
      "moduleResolution": "node"
    },
    "include": ["src/**/*"]
  }